\fancyfoot[L]{\small\textcopyright\ Ecole Supérieure des Communications de Tunis}
\fancyfoot[R]{\small Page \thepage}
\renewcommand{\footrulewidth}{0.4pt}

% Re-define 'plain' style for chapter starts
\fancypagestyle{plain}{%
    \fancyhf{}%
    \fancyfoot[L]{\small\textcopyright\ Ecole Supérieure des Communications de Tunis}%
    \fancyfoot[R]{\small Page \thepage}%
    \renewcommand{\headrulewidth}{0pt}%
    \renewcommand{\footrulewidth}{0.4pt}%
}

